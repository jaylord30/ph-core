@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sct: <http://snomed.info/id/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<http://doh.gov.ph/fhir/ph-core/Condition/condition-single-example> a fhir:Condition ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "condition-single-example"] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">Juan Dela Cruz has an active diagnosis of Type 2 Diabetes Mellitus.</div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:clinicalStatus [
     fhir:coding ( [
       fhir:system [
         fhir:v "http://terminology.hl7.org/CodeSystem/condition-clinical"^^xsd:anyURI ;
         fhir:l <http://terminology.hl7.org/CodeSystem/condition-clinical>
       ] ;
       fhir:code [ fhir:v "active" ] ;
       fhir:display [ fhir:v "Active" ]
     ] )
  ] ; # 
  fhir:code [
     fhir:coding ( [
       a sct:44054006 ;
       fhir:system [
         fhir:v "http://snomed.info/sct"^^xsd:anyURI ;
         fhir:l <http://snomed.info/sct>
       ] ;
       fhir:code [ fhir:v "44054006" ] ;
       fhir:display [ fhir:v "Diabetes mellitus type 2" ]
     ] )
  ] ; # 
  fhir:subject [
     fhir:l <http://doh.gov.ph/fhir/ph-core/Patient/patient-single-example> ;
     fhir:reference [ fhir:v "Patient/patient-single-example" ]
  ] ; # 
  fhir:encounter [
     fhir:l <http://doh.gov.ph/fhir/ph-core/Encounter/encounter-single-example> ;
     fhir:reference [ fhir:v "Encounter/encounter-single-example" ]
  ] . # 

