# - resource -------------------------------------------------------------------

<http://doh.gov.ph/fhir/ph-core/Medication/medication-single-example> a fhir:Medication ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "medication-single-example"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://doh.gov.ph/fhir/ph-core/StructureDefinition/ph-core-medication"^^xsd:anyURI ;
       fhir:l <http://doh.gov.ph/fhir/ph-core/StructureDefinition/ph-core-medication>
     ] )
  ] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">A medication resource has been created, but no specific details are provided.</div>"^^rdf:XMLLiteral ]
  ] . # 

